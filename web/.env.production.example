# Copy to `.env.production` or configure via secret manager — never commit real secrets.
NODE_ENV=production
USE_MOCK_DATA=false
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"
SESSION_SECRET="replace-with-production-secret"
DATA_ENCRYPTION_KEY="replace-with-production-data-encryption-key"
INTERNAL_SERVICE_SECRET="replace-with-production-internal-service-secret"
NEXT_PUBLIC_BASE_URL="https://your.domain"
API_KEY_HASH_PEPPER="replace-with-long-random-pepper"
