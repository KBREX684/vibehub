# VibeHub — Production Environment Template
# Copy to `.env.production` or configure via secret manager — NEVER commit real secrets.
#
# Legend:
#   🔴 REQUIRED  — startup fails without this in enforcement mode
#   🟡 RECOMMENDED — strongly suggested for full feature set
#   ⚪ OPTIONAL  — safe defaults exist

# ────────────────────────────────────────────
#  Core
# ────────────────────────────────────────────

# 🔴 REQUIRED
NODE_ENV=production
USE_MOCK_DATA=false
ENFORCE_REQUIRED_ENV=true

# ────────────────────────────────────────────
#  Database
# ────────────────────────────────────────────

# 🔴 REQUIRED — PostgreSQL connection string
# Recommended params: ?schema=public&connection_limit=10&pool_timeout=10&connect_timeout=10&statement_timeout=10000
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"

# ⚪ OPTIONAL — log Prisma queries slower than N ms (0 = disabled)
# PRISMA_SLOW_QUERY_MS=200

# ⚪ OPTIONAL — application-level query timeout in ms (default 10000)
# PRISMA_QUERY_TIMEOUT_MS=10000

# ⚪ OPTIONAL — log all Prisma queries (verbose, not for production)
# PRISMA_LOG_QUERIES=false

# ────────────────────────────────────────────
#  Auth & Security
# ────────────────────────────────────────────

# 🔴 REQUIRED — long random string for session signing
SESSION_SECRET="replace-with-production-secret"

# 🔴 REQUIRED — GitHub OAuth application credentials
GITHUB_CLIENT_ID="your-github-oauth-app-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-app-client-secret"

# 🔴 REQUIRED — public base URL (used for OAuth callbacks, email links)
NEXT_PUBLIC_BASE_URL="https://your.domain"

# 🔴 REQUIRED — pepper for hashing API key secrets (SHA-256)
API_KEY_HASH_PEPPER="replace-with-long-random-pepper"

# 🟡 RECOMMENDED — trust proxy X-Forwarded-For headers (set true behind nginx/cloudflare)
# TRUST_IP_HEADERS=true

# ⚪ OPTIONAL — internal service-to-service auth (WS server → Next.js API)
# INTERNAL_SERVICE_SECRET="replace-with-a-long-random-secret"

# ⚪ OPTIONAL — custom WebSocket token secret (defaults to SESSION_SECRET derivative)
# CHAT_WS_TOKEN_SECRET="replace-with-a-long-random-secret"
# CHAT_TOKEN_TTL_SECONDS=120

# ────────────────────────────────────────────
#  Rate Limiting
# ────────────────────────────────────────────

# ⚪ OPTIONAL — per-minute limits (sensible defaults built in)
# API_KEY_RATE_LIMIT_PER_MINUTE=120
# API_KEY_RATE_LIMIT_PER_MINUTE_READ_PUBLIC=240
# API_KEY_RATE_LIMIT_PER_MINUTE_WRITE=90
# WRITE_RATE_LIMIT_PER_MINUTE=30
# GET_RATE_LIMIT_PER_MINUTE=300
# SEARCH_RATE_LIMIT_PER_MINUTE=60
# MCP_USER_TOOL_MAX_PER_MINUTE=60

# ────────────────────────────────────────────
#  Redis (optional — enables distributed rate limiting & chat scaling)
# ────────────────────────────────────────────

# 🟡 RECOMMENDED for multi-instance deployments
# REDIS_URL="redis://production-redis:6379"

# ────────────────────────────────────────────
#  WebSocket (team chat)
# ────────────────────────────────────────────

# ⚪ OPTIONAL — defaults to same-origin /ws behind nginx
# NEXT_PUBLIC_WS_URL="wss://your.domain/ws"
# WS_PORT=3001
# WS_PATH=/ws
# WS_HEALTH_URL="http://127.0.0.1:3001/health"

# ────────────────────────────────────────────
#  Notifications
# ────────────────────────────────────────────

# ⚪ OPTIONAL — SSE tuning
# NOTIFICATIONS_SSE_POLL_MS=15000
# NOTIFICATIONS_SSE_MAX_DURATION_MS=600000
# NOTIFICATIONS_SSE_MAX_ERRORS=5

# ⚪ OPTIONAL — outbound notification webhook
# NOTIFICATION_WEBHOOK_URL="https://hooks.example.com/vibehub-notify"
# NOTIFICATION_WEBHOOK_SECRET="shared-secret-for-hmac-sha256-body-signature"

# ────────────────────────────────────────────
#  Stripe (billing)
# ────────────────────────────────────────────

# 🟡 RECOMMENDED if billing is enabled
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ────────────────────────────────────────────
#  S3 (file uploads)
# ────────────────────────────────────────────

# 🟡 RECOMMENDED if file uploads are enabled
# S3_BUCKET=vibehub-uploads
# S3_REGION=auto
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.your.domain

# ────────────────────────────────────────────
#  SMTP (email notifications)
# ────────────────────────────────────────────

# ⚪ OPTIONAL — all vars required if SMTP_HOST is set
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASS="secret"
# SMTP_FROM="VibeHub <noreply@example.com>"

# ────────────────────────────────────────────
#  GitHub README Sync
# ────────────────────────────────────────────

# 🟡 RECOMMENDED — raises GitHub API rate limit for README fetching
# GITHUB_TOKEN="ghp_..."

# ────────────────────────────────────────────
#  Background Queues (pg-boss)
# ────────────────────────────────────────────

# ⚪ OPTIONAL — defaults shown
# USE_WEBHOOK_QUEUE=true
# USE_ASYNC_CREDIT=false

# ────────────────────────────────────────────
#  Content Moderation
# ────────────────────────────────────────────

# ⚪ OPTIONAL — comma-separated blocked words/phrases
# CONTENT_SAFETY_BLOCKED=

# ────────────────────────────────────────────
#  Data Retention
# ────────────────────────────────────────────

# ⚪ OPTIONAL — days to retain (0 = forever)
# CHAT_RETAIN_DAYS=30
# COMMENT_RETAIN_DAYS=0

# ────────────────────────────────────────────
#  Misc
# ────────────────────────────────────────────

# ⚪ OPTIONAL
# EMBED_CORS_ORIGINS="https://myblog.com"
# LOG_LEVEL=info
# DISABLE_DEMO_LOGIN=true

