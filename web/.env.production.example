# Copy to `.env.production` or configure via secret manager — never commit real secrets.
NODE_ENV=production
USE_MOCK_DATA=false
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"
SESSION_SECRET="replace-with-production-secret"
NEXT_PUBLIC_BASE_URL="https://your.domain"
API_KEY_HASH_PEPPER="replace-with-long-random-pepper"
# REDIS_URL="redis://production-redis:6379"
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."

# G-01: SMTP for magic link authentication
# SMTP_HOST="smtp.your-provider.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-smtp-user"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="noreply@your.domain"

# G-08: Payment provider (default: stripe)
# PAYMENT_PROVIDER="stripe"
# NEXT_PUBLIC_PAYMENT_PROVIDER="stripe"

# G-04: These are required in production (enforced at startup):
# SESSION_SECRET, DATABASE_URL, API_KEY_HASH_PEPPER
ENFORCE_REQUIRED_ENV=true
