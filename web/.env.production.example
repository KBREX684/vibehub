# Copy to `.env.production` or configure via secret manager — never commit real secrets.
NODE_ENV=production
USE_MOCK_DATA=false
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"
SESSION_SECRET="replace-with-production-secret"
NEXT_PUBLIC_BASE_URL="https://your.domain"
API_KEY_HASH_PEPPER="replace-with-long-random-pepper"

# P4-BE-4: require SESSION_SECRET (and DATABASE_URL when USE_MOCK_DATA=false) on startup.
ENFORCE_REQUIRED_ENV=true

# Redis (recommended for distributed rate limiting and WS scaling).
# REDIS_URL="redis://production-redis:6379"

# GitHub OAuth.
# GITHUB_CLIENT_ID="production-oauth-client-id"
# GITHUB_CLIENT_SECRET="production-oauth-client-secret"

# Stripe billing.
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Internal WS server trust secret.
# INTERNAL_SERVICE_SECRET="replace-with-production-secret"

# P3-BE-5: higher GitHub API rate limits for README sync.
# GITHUB_TOKEN=

# P4-BE-2: log Prisma queries slower than N ms.
# PRISMA_SLOW_QUERY_MS=200

# S3-compatible presigned uploads.
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
