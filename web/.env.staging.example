# Copy to `.env.staging` (or inject via your host) for staging deployments.
NODE_ENV=production
USE_MOCK_DATA=false
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"
SESSION_SECRET="replace-with-staging-secret"
DATA_ENCRYPTION_KEY="replace-with-staging-data-encryption-key"
INTERNAL_SERVICE_SECRET="replace-with-staging-internal-service-secret"
NEXT_PUBLIC_BASE_URL="https://staging.example.com"
# REDIS_URL="redis://staging-redis:6379"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-user"
# SMTP_PASS="smtp-password"
# SMTP_FROM="VibeHub <noreply@example.com>"
# PRISMA_LOG_QUERIES=true
