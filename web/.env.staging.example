# Copy to `.env.staging` (or inject via your host) for staging deployments.
NODE_ENV=production
USE_MOCK_DATA=false
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"
SESSION_SECRET="replace-with-staging-secret"
NEXT_PUBLIC_BASE_URL="https://staging.example.com"
# REDIS_URL="redis://staging-redis:6379"
# PRISMA_LOG_QUERIES=true
