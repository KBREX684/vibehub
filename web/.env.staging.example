# Copy to `.env.staging` (or inject via your host) for staging deployments.
NODE_ENV=production
USE_MOCK_DATA=false
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub?schema=public"
SESSION_SECRET="replace-with-staging-secret"
NEXT_PUBLIC_BASE_URL="https://staging.example.com"
API_KEY_HASH_PEPPER="replace-with-staging-pepper"

# P4-BE-4: require SESSION_SECRET (and DATABASE_URL when USE_MOCK_DATA=false) on startup.
# Set to true for all staging/production deployments.
ENFORCE_REQUIRED_ENV=true

# Optional: Redis for distributed rate limiting and team chat scaling.
# REDIS_URL="redis://staging-redis:6379"

# GitHub OAuth (required for login in staging).
# GITHUB_CLIENT_ID="staging-oauth-client-id"
# GITHUB_CLIENT_SECRET="staging-oauth-client-secret"

# Rate limits (per minute, per IP).  Defaults shown.
# WRITE_RATE_LIMIT_PER_MINUTE=30
# GET_RATE_LIMIT_PER_MINUTE=300
# SEARCH_RATE_LIMIT_PER_MINUTE=60

# P4-BE-2: log Prisma queries slower than N ms.
# PRISMA_SLOW_QUERY_MS=200

# Enable query-level logging for debugging.
# PRISMA_LOG_QUERIES=true

# Stripe (required to test billing flows in staging).
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# S3-compatible presigned uploads (optional).
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# Internal WS server trust secret.
# INTERNAL_SERVICE_SECRET="replace-with-staging-secret"

# P3-BE-5: higher GitHub API rate limits for README sync.
# GITHUB_TOKEN=

# Async webhook queue (pg-boss).
# USE_WEBHOOK_QUEUE=true
