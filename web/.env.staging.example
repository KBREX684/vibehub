# VibeHub — Staging Environment Template
# Copy to `.env.staging` or inject via your CI/CD — NEVER commit real secrets.
#
# Staging mirrors production config but with relaxed constraints and
# verbose logging to aid debugging.

# ────────────────────────────────────────────
#  Core
# ────────────────────────────────────────────
NODE_ENV=production
USE_MOCK_DATA=false
ENFORCE_REQUIRED_ENV=true

# ────────────────────────────────────────────
#  Database
# ────────────────────────────────────────────

# 🔴 REQUIRED
DATABASE_URL="postgresql://USER:PASS@HOST:5432/vibehub_staging?schema=public"

# Enable verbose query logging for staging debugging
PRISMA_LOG_QUERIES=true
PRISMA_SLOW_QUERY_MS=100
# PRISMA_QUERY_TIMEOUT_MS=10000

# ────────────────────────────────────────────
#  Auth & Security
# ────────────────────────────────────────────

# 🔴 REQUIRED
SESSION_SECRET="replace-with-staging-secret"
NEXT_PUBLIC_BASE_URL="https://staging.example.com"

# 🟡 RECOMMENDED for OAuth testing
# GITHUB_CLIENT_ID="staging-github-client-id"
# GITHUB_CLIENT_SECRET="staging-github-client-secret"

# 🟡 RECOMMENDED
# API_KEY_HASH_PEPPER="replace-with-staging-pepper"

# Trust proxy headers in staging (typical behind load balancer)
# TRUST_IP_HEADERS=true

# ────────────────────────────────────────────
#  Redis
# ────────────────────────────────────────────

# 🟡 RECOMMENDED for staging
# REDIS_URL="redis://staging-redis:6379"

# ────────────────────────────────────────────
#  WebSocket
# ────────────────────────────────────────────

# NEXT_PUBLIC_WS_URL="wss://staging.example.com/ws"
# WS_PORT=3001
# WS_PATH=/ws
# WS_HEALTH_URL="http://127.0.0.1:3001/health"

# ────────────────────────────────────────────
#  Stripe (use test keys in staging)
# ────────────────────────────────────────────

# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_PRO="price_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ────────────────────────────────────────────
#  S3 (use separate staging bucket)
# ────────────────────────────────────────────

# S3_BUCKET=vibehub-staging-uploads
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# ────────────────────────────────────────────
#  SMTP
# ────────────────────────────────────────────

# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="apikey"
# SMTP_PASS="secret"
# SMTP_FROM="VibeHub Staging <noreply-staging@example.com>"

# ────────────────────────────────────────────
#  Notifications
# ────────────────────────────────────────────

# NOTIFICATIONS_SSE_POLL_MS=15000
# NOTIFICATION_WEBHOOK_URL=
# NOTIFICATION_WEBHOOK_SECRET=

# ────────────────────────────────────────────
#  Misc
# ────────────────────────────────────────────

# GITHUB_TOKEN="ghp_..."
# USE_WEBHOOK_QUEUE=true
# USE_ASYNC_CREDIT=false
# LOG_LEVEL=debug
# DISABLE_DEMO_LOGIN=false
# EMBED_CORS_ORIGINS=
# CONTENT_SAFETY_BLOCKED=
# CHAT_RETAIN_DAYS=30
# COMMENT_RETAIN_DAYS=0

