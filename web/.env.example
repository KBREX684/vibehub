# Real Prisma/PostgreSQL is the preferred verification path.
# Leave USE_MOCK_DATA unset for normal local work so the app can use the DB
# when configured and fall back to mock only in development.
# Production-like environments must always provide DATABASE_URL + SESSION_SECRET
# and must never set USE_MOCK_DATA=true.
# USE_MOCK_DATA=true

# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vibehub?schema=public"
DATABASE_URL=""

NODE_ENV=development

# When the app sits behind a trusted reverse proxy that sets X-Forwarded-For / X-Real-IP, set to true.
# Leave unset/false in local dev so client-supplied X-Forwarded-For is ignored for rate limiting.
# TRUST_IP_HEADERS=false

# Comma-separated origins allowed to call embed JSON with credentials (GET /api/v1/embed/*).
# Example: EMBED_CORS_ORIGINS="https://myblog.com,https://www.myblog.com"
# EMBED_CORS_ORIGINS=

# Demo login (/api/v1/auth/demo-login) only runs when NODE_ENV=development (next dev).
# Set to true to block demo-login even in local dev.
# DISABLE_DEMO_LOGIN=false

# stdio MCP (mcp-server.ts): refuses production + DATABASE_URL unless explicitly allowed.
# ALLOW_PRODUCTION_MCP_STDIO=false

# Required in production. Must be a long random string.
# Also required in development when DATABASE_URL is set (avoids fixed dev secrets against a real DB).
SESSION_SECRET="replace-with-a-long-random-secret"

# Required in production-like environments. Used for encrypting webhook secrets
# and third-party automation credentials before they are persisted to the database.
# DATA_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# GitHub OAuth (F-1). Required for production login.
# GITHUB_CLIENT_ID="your-github-oauth-app-client-id"
# GITHUB_CLIENT_SECRET="your-github-oauth-app-client-secret"
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# P4: pepper for hashing API key secrets (SHA-256). Required in production if API keys are used.
# API_KEY_HASH_PEPPER="replace-with-a-long-random-pepper"

# P4-3: max Bearer API key requests per key+IP per rolling minute (default 120)
# API_KEY_RATE_LIMIT_PER_MINUTE=120
# Optional per-scope API key limits (P2-BE-4):
# API_KEY_RATE_LIMIT_PER_MINUTE_READ_PUBLIC=240
# API_KEY_RATE_LIMIT_PER_MINUTE_WRITE=90

# Middleware IP limits (per minute, P2-BE-4):
# WRITE_RATE_LIMIT_PER_MINUTE=30
# GET_RATE_LIMIT_PER_MINUTE=300
# SEARCH_RATE_LIMIT_PER_MINUTE=60

# W8: Redis is required in production-like environments for distributed request limits,
# MCP/agent write throttles, WS fan-out, and alert/health readiness.
# Development can fall back to in-memory state when REDIS_URL is absent.
# REDIS_URL="redis://127.0.0.1:6379"

# Team chat WebSocket URL for the browser (defaults to same-origin `/ws` behind nginx, or :3001/ws in local dev)
# NEXT_PUBLIC_WS_URL="wss://your.domain/ws"

# Standalone chat WebSocket server (see `npm run ws:serve`, `infra/pm2/ecosystem.config.cjs`)
# WS_PORT=3001
# WS_PATH=/ws
# Health check: HTTP GET this URL from the Next.js process (e.g. http://127.0.0.1:3001/health)
# WS_HEALTH_URL="http://127.0.0.1:3001/health"

# P3-BE-1: async outbound webhooks via pg-boss (uses DATABASE_URL). Set "false" to deliver inline.
# USE_WEBHOOK_QUEUE=true

# P3-BE-1: async contribution credit bumps (opt-in; same pg-boss instance)
# USE_ASYNC_CREDIT=true

# P4-BE-2: log Prisma queries slower than N ms (server-side)
# PRISMA_SLOW_QUERY_MS=200

# P4-BE-4: when "true", all production-like processes refuse to start without
# DATABASE_URL + SESSION_SECRET and reject USE_MOCK_DATA=true.
# ENFORCE_REQUIRED_ENV=false

# P3-BE-3: S3-compatible presigned uploads (optional)
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# Set to true only if uploaded objects are intentionally public behind a CDN/bucket website.
# S3_UPLOADS_PUBLIC=false
# Public URL prefix for uploaded objects (CDN or bucket website)
# S3_PUBLIC_BASE_URL=

# P3-BE-5: higher GitHub API rate limits for README sync
# GITHUB_TOKEN=

# Internal trust secret for WS server -> Next.js API calls.
# Required in production when ws-server is enabled.
# INTERNAL_SERVICE_SECRET="replace-with-a-long-random-secret"

# Optional: outbound notification webhook (JSON POST on each in-app notification after DB write)
# NOTIFICATION_WEBHOOK_URL="https://hooks.example.com/vibehub-notify"
# NOTIFICATION_WEBHOOK_SECRET="shared-secret-for-hmac-sha256-body-signature"

# Notification stream polling interval in milliseconds (SSE snapshot push cadence)
# NOTIFICATIONS_SSE_POLL_MS=15000

# M-2: Stripe payment gateway (required for billing features)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."      # required for /api/v1/billing/webhook (unsigned requests are rejected)
# STRIPE_PRICE_PRO="price_..."           # Pro plan (¥29/mo or overseas equivalent) Stripe price ID
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# W6: China-local payment channels. In production-like environments, sandbox mode is rejected.
# ALIPAY_MODE="sandbox"                  # "sandbox" or "live"
# ALIPAY_GATEWAY_URL="https://openapi.alipay.com/gateway.do"
# ALIPAY_APP_ID="2021000000000000"
# ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# ALIPAY_PRODUCT_CODE="FAST_INSTANT_TRADE_PAY"
#
# WECHATPAY_MODE="sandbox"               # "sandbox" or "live"
# WECHATPAY_API_BASE_URL="https://api.mch.weixin.qq.com"
# WECHATPAY_APP_ID="wx1234567890abcdef"
# WECHATPAY_MCH_ID="1230000109"
# WECHATPAY_SERIAL_NO="serial-number-from-merchant-cert"
# WECHATPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# WECHATPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# WECHATPAY_API_V3_KEY="32-byte-api-v3-key"

# Production email auth depends on SMTP. Configure all of the following before
# enabling the email registration / verification / reset flow in production.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="apikey"
# SMTP_PASS="secret"
# SMTP_FROM="VibeHub <noreply@example.com>"

# W7/W8: admin AI provider (optional; falls back to heuristic when omitted)
# ADMIN_AI_PROVIDER_NAME="qwen-compatible"
# ADMIN_AI_PROVIDER_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# ADMIN_AI_PROVIDER_API_KEY="replace-with-provider-key"
# ADMIN_AI_MODEL="qwen-plus"

# W8: alert delivery channels (optional; alerts are still stored in-app if omitted)
# FEISHU_ALERT_WEBHOOK_URL="https://open.feishu.cn/open-apis/bot/v2/hook/..."
# ALERT_EMAIL_TO="ops@example.com"
