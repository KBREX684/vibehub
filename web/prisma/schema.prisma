generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  guest
  user
  admin
}

enum ProjectStatus {
  idea
  building
  launched
  paused
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum CollaborationIntentType {
  join
  recruit
}

model User {
  id                        String           @id @default(cuid())
  email                     String           @unique
  name                      String
  role                      Role             @default(user)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  creatorProfile            CreatorProfile?
  posts                     Post[]           @relation("PostAuthor")
  reviewedPosts             Post[]           @relation("PostReviewer")
  comments                  Comment[]
  resolvedModerationCases   ModerationCase[] @relation("ModerationResolvedBy")
  reportTickets             ReportTicket[]   @relation("ReportReporter")
  resolvedReportTickets     ReportTicket[]   @relation("ReportResolvedBy")
  auditLogs                 AuditLog[]
  collaborationIntents      CollaborationIntent[] @relation("CollaborationApplicant")
  reviewedCollabIntents     CollaborationIntent[] @relation("CollaborationReviewer")
}

model CreatorProfile {
  id                      String    @id @default(cuid())
  slug                    String    @unique
  userId                  String    @unique
  headline                String
  bio                     String
  skills                  String[]
  collaborationPreference String    @default("open")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects                Project[]
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  creatorId   String
  title       String
  oneLiner    String
  description String
  techStack   String[]
  tags        String[]
  status      ProjectStatus @default(idea)
  demoUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  collaborationIntents CollaborationIntent[]

  @@index([creatorId])
}

model Post {
  id               String          @id @default(cuid())
  slug             String          @unique
  authorId         String
  title            String
  body             String
  tags             String[]
  reviewStatus     ReviewStatus    @default(pending)
  moderationNote   String?
  reviewedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  author           User            @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewer         User?           @relation("PostReviewer", fields: [reviewedBy], references: [id])
  comments         Comment[]
  moderationCases  ModerationCase[]
  reportTickets    ReportTicket[]

  @@index([authorId])
  @@index([reviewStatus])
  @@index([reviewedBy])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model ModerationCase {
  id         String       @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  status     ReviewStatus @default(pending)
  reason     String?
  note       String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  post       Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  resolver   User?        @relation("ModerationResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model ReportTicket {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  reporterId String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver   User?    @relation("ReportResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entityType, entityId])
}

model CollaborationIntent {
  id          String                  @id @default(cuid())
  projectId   String
  applicantId String
  intentType  CollaborationIntentType
  message     String
  contact     String?
  status      ReviewStatus            @default(pending)
  reviewNote  String?
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicant   User                    @relation("CollaborationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewer    User?                   @relation("CollaborationReviewer", fields: [reviewedBy], references: [id])

  @@index([projectId])
  @@index([applicantId])
  @@index([status])
  @@index([reviewedBy])
}
