generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  guest
  user
  admin
}

enum SubscriptionTier {
  free
  pro
  team_pro
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
}

enum ProjectStatus {
  idea
  building
  launched
  paused
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum CollaborationIntentType {
  join
  recruit
}

enum WeeklyLeaderboardKind {
  discussions_by_weekly_comment_count
  projects_by_weekly_collaboration_intent_count
}

enum TeamRole {
  owner
  member
}

enum TeamJoinRequestStatus {
  pending
  approved
  rejected
}

enum TeamTaskStatus {
  todo
  doing
  done
}

enum InAppNotificationKind {
  team_join_request
  team_join_approved
  team_join_rejected
  team_task_assigned
  post_commented
  comment_replied
  post_liked
  project_bookmarked
  user_followed
  project_intent_received
  post_featured
}

model User {
  id                        String           @id @default(cuid())
  email                     String           @unique
  name                      String
  role                      Role             @default(user)
  githubId                  Int?             @unique
  githubUsername             String?          @unique
  avatarUrl                 String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  creatorProfile            CreatorProfile?
  posts                     Post[]           @relation("PostAuthor")
  reviewedPosts             Post[]           @relation("PostReviewer")
  comments                  Comment[]
  resolvedModerationCases   ModerationCase[] @relation("ModerationResolvedBy")
  reportTickets             ReportTicket[]   @relation("ReportReporter")
  resolvedReportTickets     ReportTicket[]   @relation("ReportResolvedBy")
  auditLogs                 AuditLog[]
  collaborationIntents      CollaborationIntent[] @relation("CollaborationApplicant")
  reviewedCollabIntents     CollaborationIntent[] @relation("CollaborationReviewer")
  ownedTeams                Team[]                @relation("TeamOwner")
  teamMemberships           TeamMembership[]
  teamJoinRequests          TeamJoinRequest[]     @relation("TeamJoinApplicant")
  teamTasksCreated          TeamTask[]            @relation("TeamTaskCreator")
  teamTasksAssigned         TeamTask[]            @relation("TeamTaskAssignee")
  teamMilestonesCreated     TeamMilestone[]       @relation("TeamMilestoneCreator")
  apiKeys                   ApiKey[]
  notifications             InAppNotification[]
  subscription              UserSubscription?
  /// M-2: Stripe customer ID
  stripeCustomerId          String?              @unique
  /// C-1: users this user follows
  following                 UserFollow[]          @relation("Follower")
  /// C-1: users following this user
  followers                 UserFollow[]          @relation("Following")
  postLikes                 PostLike[]
  postBookmarks             PostBookmark[]
  projectBookmarks          ProjectBookmark[]
}

/// M-1: user subscription plan
model UserSubscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 SubscriptionTier   @default(free)
  status               SubscriptionStatus @default(active)
  /// M-2: Stripe subscription ID
  stripeSubscriptionId String?            @unique
  /// M-2: Stripe price ID
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
}

/// C-1: follow relationship between users
model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

/// C-1: post like
model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
}

/// C-1: post bookmark
model PostBookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

/// C-1: project bookmark
model ProjectBookmark {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model InAppNotification {
  id        String                @id @default(cuid())
  userId    String
  kind      InAppNotificationKind
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// MCP v2 HTTP invoke audit (Bearer or session).
model McpInvokeAudit {
  id           String   @id @default(cuid())
  tool         String
  userId       String
  apiKeyId     String?
  httpStatus   Int
  clientIp     String?
  userAgent    String?
  errorCode    String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([tool, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  label      String
  keyHash    String    @unique
  prefix     String
  /// JSON string[] of scope tokens (e.g. read:public, read:projects:list)
  scopes     Json
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreatorProfile {
  id                      String    @id @default(cuid())
  slug                    String    @unique
  userId                  String    @unique
  headline                String
  bio                     String
  skills                  String[]
  collaborationPreference String    @default("open")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects                Project[]
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  creatorId   String
  teamId      String?
  title       String
  oneLiner    String
  description String
  techStack   String[]
  tags        String[]
  status      ProjectStatus @default(idea)
  demoUrl     String?
  repoUrl     String?
  websiteUrl  String?
  screenshots String[]
  logoUrl     String?
  openSource  Boolean       @default(false)
  license     String?
  /// C-5: admin-set daily featured rank (null = not featured today)
  featuredRank Int?
  /// C-5: when featuredRank was last set (for auto-clear next UTC day)
  featuredAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  team        Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  collaborationIntents CollaborationIntent[]
  bookmarks            ProjectBookmark[]

  @@index([creatorId])
  @@index([teamId])
  @@index([featuredRank])
}

model Post {
  id               String          @id @default(cuid())
  slug             String          @unique
  authorId         String
  title            String
  body             String
  tags             String[]
  reviewStatus     ReviewStatus    @default(pending)
  moderationNote   String?
  reviewedAt       DateTime?
  reviewedBy       String?
  /// C-4: admin-curated featured post (non-null = featured today)
  featuredAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  author           User            @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewer         User?           @relation("PostReviewer", fields: [reviewedBy], references: [id])
  comments         Comment[]
  moderationCases  ModerationCase[]
  reportTickets    ReportTicket[]
  likes            PostLike[]
  bookmarks        PostBookmark[]

  @@index([authorId])
  @@index([reviewStatus])
  @@index([reviewedBy])
  @@index([featuredAt])
}

model Comment {
  id              String    @id @default(cuid())
  postId          String
  authorId        String
  body            String
  /// C-2: optional parent for nested replies (max depth 2)
  parentCommentId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
}

model ModerationCase {
  id         String       @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  status     ReviewStatus @default(pending)
  reason     String?
  note       String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  post       Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  resolver   User?        @relation("ModerationResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model ReportTicket {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  reporterId String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver   User?    @relation("ReportResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entityType, entityId])
}

model CollaborationIntent {
  id                         String                  @id @default(cuid())
  projectId                  String
  applicantId                String
  intentType                 CollaborationIntentType
  message                    String
  contact                    String?
  status                     ReviewStatus            @default(pending)
  reviewNote                 String?
  reviewedAt                 DateTime?
  reviewedBy                 String?
  /// T-4: true when intent led to a TeamMembership
  convertedToTeamMembership  Boolean                 @default(false)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  project                    Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicant                  User                    @relation("CollaborationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewer                   User?                   @relation("CollaborationReviewer", fields: [reviewedBy], references: [id])

  @@index([projectId])
  @@index([applicantId])
  @@index([status])
  @@index([reviewedBy])
}

/// UTC week starting Monday 00:00:00. Materialized ranking rows for stable weekly leaderboards.
model WeeklyLeaderboardSnapshot {
  id          String               @id @default(cuid())
  weekStart   DateTime
  kind        WeeklyLeaderboardKind
  generatedAt DateTime             @default(now())
  rows        WeeklyLeaderboardRow[]

  @@unique([weekStart, kind])
  @@index([weekStart])
}

model WeeklyLeaderboardRow {
  id         String                   @id @default(cuid())
  snapshotId String
  rank       Int
  entityId   String
  score      Int
  slug       String
  title      String
  snapshot   WeeklyLeaderboardSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}

model Team {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  mission       String?
  ownerUserId   String
  /// T-1: external chat links (optional)
  discordUrl    String?
  telegramUrl   String?
  slackUrl      String?
  /// T-3: GitHub org or repo URL for the team
  githubOrgUrl  String?
  githubRepoUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  memberships   TeamMembership[]
  joinRequests  TeamJoinRequest[]
  projects      Project[]
  tasks         TeamTask[]
  milestones    TeamMilestone[]

  @@index([ownerUserId])
}

model TeamMembership {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(member)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamJoinRequest {
  id          String                 @id @default(cuid())
  teamId      String
  applicantId String
  message     String                 @default("")
  status      TeamJoinRequestStatus  @default(pending)
  reviewedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  team        Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  applicant   User                   @relation("TeamJoinApplicant", fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([teamId, applicantId])
  @@index([teamId, status])
  @@index([applicantId])
}

model TeamTask {
  id                String         @id @default(cuid())
  teamId            String
  title             String
  description       String?
  status            TeamTaskStatus @default(todo)
  sortOrder         Int            @default(0)
  milestoneId       String?
  createdByUserId   String
  assigneeUserId    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  team              Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  milestone         TeamMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  createdBy         User           @relation("TeamTaskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignee          User?          @relation("TeamTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, sortOrder])
  @@index([teamId, milestoneId])
}

model TeamMilestone {
  id                String   @id @default(cuid())
  teamId            String
  title             String
  description       String?
  targetDate        DateTime
  completed         Boolean  @default(false)
  sortOrder         Int      @default(0)
  /// T-2: "team_only" | "public" visibility
  visibility        String   @default("team_only")
  /// T-2: 0-100 progress percentage
  progress          Int      @default(0)
  createdByUserId   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy         User     @relation("TeamMilestoneCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  tasks             TeamTask[]

  @@index([teamId])
  @@index([teamId, completed])
  @@index([teamId, sortOrder])
  @@index([teamId, visibility])
}
