generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  guest
  user
  admin
}

enum ProjectStatus {
  idea
  building
  launched
  paused
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum CollaborationIntentType {
  join
  recruit
}

enum WeeklyLeaderboardKind {
  discussions_by_weekly_comment_count
  projects_by_weekly_collaboration_intent_count
}

enum TeamRole {
  owner
  member
}

enum TeamJoinRequestStatus {
  pending
  approved
  rejected
}

enum TeamTaskStatus {
  todo
  doing
  done
}

enum InAppNotificationKind {
  team_join_request
  team_join_approved
  team_join_rejected
  team_task_assigned
}

model User {
  id                        String           @id @default(cuid())
  email                     String           @unique
  name                      String
  role                      Role             @default(user)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  creatorProfile            CreatorProfile?
  posts                     Post[]           @relation("PostAuthor")
  reviewedPosts             Post[]           @relation("PostReviewer")
  comments                  Comment[]
  resolvedModerationCases   ModerationCase[] @relation("ModerationResolvedBy")
  reportTickets             ReportTicket[]   @relation("ReportReporter")
  resolvedReportTickets     ReportTicket[]   @relation("ReportResolvedBy")
  auditLogs                 AuditLog[]
  collaborationIntents      CollaborationIntent[] @relation("CollaborationApplicant")
  reviewedCollabIntents     CollaborationIntent[] @relation("CollaborationReviewer")
  ownedTeams                Team[]                @relation("TeamOwner")
  teamMemberships           TeamMembership[]
  teamJoinRequests          TeamJoinRequest[]     @relation("TeamJoinApplicant")
  teamTasksCreated          TeamTask[]            @relation("TeamTaskCreator")
  teamTasksAssigned         TeamTask[]            @relation("TeamTaskAssignee")
  teamMilestonesCreated     TeamMilestone[]       @relation("TeamMilestoneCreator")
  apiKeys                   ApiKey[]
  notifications             InAppNotification[]
}

model InAppNotification {
  id        String                @id @default(cuid())
  userId    String
  kind      InAppNotificationKind
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

/// MCP v2 HTTP invoke audit (Bearer or session).
model McpInvokeAudit {
  id           String   @id @default(cuid())
  tool         String
  userId       String
  apiKeyId     String?
  httpStatus   Int
  clientIp     String?
  userAgent    String?
  errorCode    String?
  durationMs   Int?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([tool, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  label      String
  keyHash    String    @unique
  prefix     String
  /// JSON string[] of scope tokens (e.g. read:public, read:projects:list)
  scopes     Json
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreatorProfile {
  id                      String    @id @default(cuid())
  slug                    String    @unique
  userId                  String    @unique
  headline                String
  bio                     String
  skills                  String[]
  collaborationPreference String    @default("open")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects                Project[]
}

model Project {
  id          String        @id @default(cuid())
  slug        String        @unique
  creatorId   String
  teamId      String?
  title       String
  oneLiner    String
  description String
  techStack   String[]
  tags        String[]
  status      ProjectStatus @default(idea)
  demoUrl     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  team        Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  collaborationIntents CollaborationIntent[]

  @@index([creatorId])
  @@index([teamId])
}

model Post {
  id               String          @id @default(cuid())
  slug             String          @unique
  authorId         String
  title            String
  body             String
  tags             String[]
  reviewStatus     ReviewStatus    @default(pending)
  moderationNote   String?
  reviewedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  author           User            @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reviewer         User?           @relation("PostReviewer", fields: [reviewedBy], references: [id])
  comments         Comment[]
  moderationCases  ModerationCase[]
  reportTickets    ReportTicket[]

  @@index([authorId])
  @@index([reviewStatus])
  @@index([reviewedBy])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model ModerationCase {
  id         String       @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  status     ReviewStatus @default(pending)
  reason     String?
  note       String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  post       Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  resolver   User?        @relation("ModerationResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model ReportTicket {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  postId     String?
  reporterId String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  post       Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User     @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver   User?    @relation("ReportResolvedBy", fields: [resolvedBy], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entityType, entityId])
}

model CollaborationIntent {
  id          String                  @id @default(cuid())
  projectId   String
  applicantId String
  intentType  CollaborationIntentType
  message     String
  contact     String?
  status      ReviewStatus            @default(pending)
  reviewNote  String?
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  project     Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicant   User                    @relation("CollaborationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewer    User?                   @relation("CollaborationReviewer", fields: [reviewedBy], references: [id])

  @@index([projectId])
  @@index([applicantId])
  @@index([status])
  @@index([reviewedBy])
}

/// UTC week starting Monday 00:00:00. Materialized ranking rows for stable weekly leaderboards.
model WeeklyLeaderboardSnapshot {
  id          String               @id @default(cuid())
  weekStart   DateTime
  kind        WeeklyLeaderboardKind
  generatedAt DateTime             @default(now())
  rows        WeeklyLeaderboardRow[]

  @@unique([weekStart, kind])
  @@index([weekStart])
}

model WeeklyLeaderboardRow {
  id         String                   @id @default(cuid())
  snapshotId String
  rank       Int
  entityId   String
  score      Int
  slug       String
  title      String
  snapshot   WeeklyLeaderboardSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
}

model Team {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  mission     String?
  ownerUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]
  joinRequests TeamJoinRequest[]
  projects    Project[]
  tasks       TeamTask[]
  milestones  TeamMilestone[]

  @@index([ownerUserId])
}

model TeamMembership {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(member)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamJoinRequest {
  id          String                 @id @default(cuid())
  teamId      String
  applicantId String
  message     String                 @default("")
  status      TeamJoinRequestStatus  @default(pending)
  reviewedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  team        Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  applicant   User                   @relation("TeamJoinApplicant", fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([teamId, applicantId])
  @@index([teamId, status])
  @@index([applicantId])
}

model TeamTask {
  id                String         @id @default(cuid())
  teamId            String
  title             String
  description       String?
  status            TeamTaskStatus @default(todo)
  sortOrder         Int            @default(0)
  milestoneId       String?
  createdByUserId   String
  assigneeUserId    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  team              Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  milestone         TeamMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  createdBy         User           @relation("TeamTaskCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignee          User?          @relation("TeamTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, sortOrder])
  @@index([teamId, milestoneId])
}

model TeamMilestone {
  id                String   @id @default(cuid())
  teamId            String
  title             String
  description       String?
  targetDate        DateTime
  completed         Boolean  @default(false)
  sortOrder         Int      @default(0)
  createdByUserId   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy         User     @relation("TeamMilestoneCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  tasks             TeamTask[]

  @@index([teamId])
  @@index([teamId, completed])
  @@index([teamId, sortOrder])
}
